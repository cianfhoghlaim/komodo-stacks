ect","type":"n8n-nodes-base.httpRequest","position":[1450,200]},{"parameters":{"url":"={{ $env.VIKUNJA_URL }}/api/v1/tasks","method":"PUT","headers":{"Authorization":"=Bearer {{ $env.VIKUNJA_TOKEN }}","Content-Type":"application/json"},"body":{"title":"={{ \"Wiki edit flagged — \" + $json.classification + \" — \" + $json.severity + \"/5\" }}","description":"={{ $json.summary + \"\\n\\nEditor: \" + $json.editor_analysis + \"\\n\\nPrior instances: \" + ($json.prior_instances || \"none\") + \"\\n\\nRecommendation: \" + $json.recommendation }}","project_id":"={{ $json.project_id }}"}},"name":"Create Vikunja task","type":"n8n-nodes-base.httpRequest","position":[1700,200]},{"parameters":{"from":"={{ $env.TEAM_EMAIL }}","to":"={{ $env.TEAM_LEAD_EMAIL }}","subject":"={{ \"Wiki alert: \" + $json.url }}","html":"={{ \"<h2>Change detected on \" + $json.url + \"</h2><p><strong>Classification:</strong> \" + $json.classification + \" (severity \" + $json.severity + \"/5)</p><p>\" + $json.summary + \"</p><p><strong>Editor:</strong> \" + $json.editor_analysis + \"</p>\" }}"}},"name":"Email alert to team lead","type":"n8n-nodes-base.emailSend","position":[1700,400]}],"settings":{"executionOrder":"v1"},"tags":[{"name":"wiki"},{"name":"llm"},{"name":"deepseek"},{"name":"changedetection"}],"trigger":{"type":"n8n-nodes-base.webhook","parameters":{"httpMethod":"POST","path":"wiki-page-monitor"}}}