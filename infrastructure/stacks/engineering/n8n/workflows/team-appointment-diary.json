{"name":"team-appointment-diary","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":6}]}},"name":"Every 6 hours","type":"n8n-nodes-base.scheduleTrigger","position":[250,300]},{"parameters":{"url":"=https://calcom.cianfhoghlaim.ie/api/v2/bookings?status=upcoming","method":"GET","headers":{"Authorization":"=Bearer {{ $env.CALCOM_API_KEY }}"}},"name":"Fetch today + tomorrow bookings","type":"n8n-nodes-base.httpRequest","position":[500,300]},{"parameters":{"url":"={{ $env.OPENAI_BASE_URL }}/chat/completions","method":"POST","headers":{"Authorization":"=Bearer {{ $env.OPENAI_API_KEY }}","Content-Type":"application/json"},"body":{"model":"opencode-go/kimi-k2.6","messages":[{"role":"system","content":"Generate a chronological diary entry from these bookings. For each: time, event title, location, prep notes (if context available), travel estimate between sequential in-person meetings. Output as plain text diary format, grouped by day (Today/Tomorrow)."},{"role":"user","content":"={{ JSON.stringify($json.bookings) }}"}]}},"name":"LLM diary generator","type":"n8n-nodes-base.httpRequest","position":[750,300]},{"parameters":{"url":"={{ $env.VIKUNJA_URL }}/api/v1/tasks","method":"PUT","headers":{"Authorization":"=Bearer {{ $env.VIKUNJA_TOKEN }}","Content-Type":"application/json"},"body":{"title":"={{ \"Diary: \" + new Date().toISOString().slice(0,10) }}","description":"={{ $json.diary }}"}},"name":"Create Vikunja diary task","type":"n8n-nodes-base.httpRequest","position":[1000,300]},{"parameters":{"conditions":{"number":[{"value1":"={{ new Date($json.bookings[0].start).getHours() }}","operation":"smaller","value2":8}]}},"name":"Early meeting tomorrow?","type":"n8n-nodes-base.if","position":[1250,400]},{"parameters":{"from":"={{ $env.TEAM_EMAIL }}","to":"={{ $env.TEAM_LEAD_EMAIL }}","subject":"Reminder: Early meeting tomorrow","html":"={{ \"<h2>Early start tomorrow</h2><p>Your first booking is at \" + new Date($json.bookings[0].start).toLocaleTimeString