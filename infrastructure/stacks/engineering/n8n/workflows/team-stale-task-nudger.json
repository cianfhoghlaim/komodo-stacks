{"name":"team-stale-task-nudger","nodes":[{"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":24}]}},"name":"Cron daily 08:00","type":"n8n-nodes-base.scheduleTrigger","position":[250,300]},{"parameters":{"url":"=http://vikunja:3456/api/v1/tasks/all?filter=stale&older_than=14d","method":"GET","headers":{"Authorization":"=Bearer {{ $env.VIKUNJA_TOKEN }}"}},"name":"Find tasks untouched for 14+ days","type":"n8n-nodes-base.httpRequest","position":[500,300]},{"parameters":{"url":"=http://litellm:4000/v1/chat/completions","method":"POST","headers":{"Authorization":"=Bearer {{ $env.OPENAI_API_KEY }}","Content-Type":"application/json"},"body":{"model":"opencode-go/mimo-v2.5","messages":[{"role":"system","content":"Classify each stale task as: stuck, abandoned, on-hold. Reply with JSON array: [{id, classification, reason}]."},{"role":"user","content":"={{ JSON.stringify($json.tasks.map(function(t){return {id:t.id, title:t.title}})) }}"}]}},"name":"Classify with mimo-v2.5 (via LiteLLM)","type":"n8n-nodes-base.httpRequest","position":[750,300]},{"parameters":{"url":"=http://vikunja:3456/api/v1/tasks/{{ $json.id }}/comments","method":"POST","headers":{"Authorization":"=Bearer {{ $env.VIKUNJA_TOKEN }}","Content-Type":"application/json"},"body":{"text":"={{ \"[n8n] Stale task check: \" + $json.classification + \" — \" + $json.reason }}"}},"name":"Comment on stale task","type":"n8n-nodes-base.httpRequest","position":[1000,300]},{"parameters":{"from":"={{ $env.TEAM_EMAIL }}","to":"={{ $env.TEAM_LEAD_EMAIL }}","subject":"={{ \"Stale task: \" + $json.title }}","html":"={{ \"<p>Task classified as <strong>\" + $json.classification + \"</strong>: \" + $json.reason + \"</p>\" }}"},"name":"Email owner","type":"n8n-nodes-base.emailSend","position":[1250,300]}],"settings":{"executionOrder":"v1"},"tags":[{"name":"team"},{"name":"llm"},{"name":"opencode-go"}]}