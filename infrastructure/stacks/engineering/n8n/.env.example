# =============================================================================
# n8n — Local development environment (no real secrets)
# =============================================================================
# Copy this file to .env.local and edit. Do NOT commit .env.local.
# Locket + sidecar.yaml override these in production.
# =============================================================================

# Generic
N8N_HOST=n8n.localhost
N8N_WEBHOOK_URL=http://n8n.localhost:5678/
GENERIC_TIMEZONE=Europe/Dublin

# Auth / encryption (dev defaults — replace in production via Locket)
N8N_ENCRYPTION_KEY=dev-encryption-key-change-me
N8N_USER_MANAGEMENT_JWT_SECRET=dev-jwt-secret-change-me
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# Postgres
N8N_POSTGRES_DB=n8n
N8N_POSTGRES_USER=n8n
N8N_DB_POSTGRES_PASSWORD=dev-postgres-password

# n8n API key (used by n8n-init to import workflows)
N8N_API_KEY=dev-api-key

# Webhook signing
N8N_WEBHOOK_SECRET=dev-webhook-secret

# LLM (OpenCode Go)
OPENAI_API_KEY=sk-dev
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1
