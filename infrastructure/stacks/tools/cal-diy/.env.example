# =============================================================================
# cal-diy — Local development environment (no real secrets)
# =============================================================================
# Copy to .env.local and edit. Do NOT commit .env.local.
# =============================================================================

CALCOM_NEXTAUTH_URL=http://localhost:3000
CALCOM_ALLOWED_HOSTNAMES=localhost,calcom.localhost

# Database
CALCOM_POSTGRES_DB=calcom
CALCOM_POSTGRES_USER=calcom
CALCOM_POSTGRES_PASSWORD=dev-postgres-password
CALCOM_DATABASE_URL=postgresql://calcom:dev-postgres-password@calcom-db:5432/calcom

# Auth + encryption
CALCOM_NEXTAUTH_SECRET=dev-nextauth-secret-change-me
CALCOM_ENCRYPTION_KEY=dev-calcom-encryption-key-change-me-32bytes

# Webhooks
CALCOM_WEBHOOK_SECRET=dev-webhook-secret
CALCOM_CRON_API_KEY=dev-cron-api-key

# Outbound mail
TEAM_SMTP_HOST=localhost
TEAM_SMTP_PORT=1025
TEAM_IMAP_USER=dev@localhost
TEAM_SMTP_PASSWORD=dev-smtp-password
TEAM_FROM_EMAIL=dev@localhost
