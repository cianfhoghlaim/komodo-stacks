# Infisical Environment Variables Example
# Copy this file to .env and fill in the values

# Secrets
# Generate a 32-byte hex string (e.g. openssl rand -hex 16)
ENCRYPTION_KEY=your-encryption-key-here
# Generate a random string (e.g. openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here

# Database
POSTGRES_USER=infisical
POSTGRES_PASSWORD=infisical_password
POSTGRES_DB=infisical
DB_CONNECTION_URI=postgres://infisical:infisical_password@db:5432/infisical

# Redis
REDIS_URL=redis://redis:6379

# Site Config
SITE_URL=https://infisical.yourdomain.com
